# Copia este archivo a .env y completa los valores.

# URL base de tu API. Si se deja vacío, la app usa la data local (modo demo).
# En Vercel, déjalo vacío para usar las funciones de /api del mismo dominio,
# o apunta a tu backend externo, p. ej. https://api.tudominio.com
VITE_API_URL=

# Servicio de ruteo usado en el navegador (opcional, para ruteo en vivo).
# Por defecto el trazado viene precalculado en route-geometries.json.
VITE_ROUTING_URL=https://router.project-osrm.org

# Servicio de ruteo usado por el script de precálculo
# (node scripts/fetch-route-geometries.mjs).
# 100% gratis sin API key. Alternativa: https://valhalla1.openstreetmap.de
ROUTING_URL=https://router.project-osrm.org
